# Backend API URL
# Local dev: leave empty (Vite proxy handles /api -> localhost:5000)
# Production (Vercel): set to your deployed backend URL
# Example: VITE_API_URL=https://api.mydomain.com  OR  https://church-backend-xxxx.onrender.com
VITE_API_URL=

# Google Sheets API (OPTIONAL) — AdminDashboard live sync
VITE_SHEET_API_URL=

# Firebase (OPTIONAL — all 6 must be filled to enable Google Sign-In + Phone OTP)
# Leave blank to disable Firebase features (password login always works)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=